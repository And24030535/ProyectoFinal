<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #121212;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.itc.healthtrack.controllers.AdminController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
    </padding>

    <!-- Title -->
    <Label text="Panel de Administración" textFill="WHITE"
           style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
    <Label text="Gestión global de usuarios registrados en el sistema HealthTrack."
           textFill="#aaaaaa" style="-fx-font-size: 12px;"/>

    <!-- Statistics cards -->
    <HBox spacing="20.0">
        <VBox alignment="CENTER" prefWidth="180.0" prefHeight="90.0" styleClass="panel-secundario" style="-fx-padding: 15;">
            <Label text="Total Usuarios" textFill="#aaaaaa" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
            <Label fx:id="lblTotalUsers" text="—" textFill="WHITE">
                <font><Font name="System Bold" size="30.0"/></font>
            </Label>
        </VBox>
        <VBox alignment="CENTER" prefWidth="180.0" prefHeight="90.0" styleClass="panel-secundario" style="-fx-padding: 15;">
            <Label text="Médicos"        textFill="#aaaaaa" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
            <Label fx:id="lblTotalDoctors" text="—" textFill="#2196f3">
                <font><Font name="System Bold" size="30.0"/></font>
            </Label>
        </VBox>
        <VBox alignment="CENTER" prefWidth="180.0" prefHeight="90.0" styleClass="panel-secundario" style="-fx-padding: 15;">
            <Label text="Pacientes"      textFill="#aaaaaa" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
            <Label fx:id="lblTotalPatients" text="—" textFill="#4caf50">
                <font><Font name="System Bold" size="30.0"/></font>
            </Label>
        </VBox>
    </HBox>

    <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="panel-secundario" style="-fx-padding: 12;">
        <Label text="Buscar:" textFill="#aaaaaa" style="-fx-font-weight: bold;"/>
        <TextField fx:id="txtSearch" promptText="Nombre, apellido o correo..."
                   prefWidth="280.0"
                   style="-fx-background-color: #2a2a2a; -fx-text-fill: white; -fx-prompt-text-fill: #666666; -fx-border-color: #444; -fx-border-radius: 4;"
                   onAction="#onSearch"/>
        <Label text="Rol:"    textFill="#aaaaaa" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbRoleFilter" prefWidth="120.0"
                  style="-fx-background-color: #2a2a2a; -fx-text-fill: white;"
                  onAction="#onSearch"/>
        <Button text="Buscar"  onAction="#onSearch"
                style="-fx-background-color: #2196f3; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 14;" />
        <Button text="Limpiar" onAction="#onClearSearch"
                style="-fx-background-color: #444444; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 14;" />
    </HBox>

    <!-- User management table -->
    <VBox spacing="10.0" VBox.vgrow="ALWAYS" styleClass="panel-secundario" style="-fx-padding: 20;">
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label text="Usuarios Registrados" textFill="WHITE"
                style="-fx-font-size: 20px; -fx-font-weight: bold "/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Eliminar Seleccionado" onAction="#onDeleteUser" styleClass="btn, btn-danger" />
            <Button text="Ver Detalles" onAction="#onViewDetails"
                    style="-fx-background-color: #9c27b0; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 14;" />
            <Button text="Cambiar Rol" onAction="#onChangeRole"
                    style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 14;" />
        </HBox>

        <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colFirstName"  text="Nombre"   prefWidth="160" />
                <TableColumn fx:id="colLastName"   text="Apellido" prefWidth="160" />
                <TableColumn fx:id="colEmail"      text="Correo"   prefWidth="240" />
                <TableColumn fx:id="colRole"       text="Rol"      prefWidth="100" />
                <TableColumn fx:id="colAssignedDoctor" text="Doctor Asignado" prefWidth="160" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <Label fx:id="lblStatus" wrapText="true" textFill="#aaaaaa" />
    </VBox>
</VBox>
